<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:core="clr-namespace:SelfCertForge.Core.Presentation;assembly=SelfCertForge.Core"
             xmlns:controls="clr-namespace:SelfCertForge.App.Controls"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="SelfCertForge.App.Pages.AboutSectionView"
             x:DataType="core:SettingsViewModel">

    <Border Style="{StaticResource CardStyle}">
        <VerticalStackLayout Spacing="16">

            <!-- Header row: app name + version -->
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                    <Grid WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                        <shapes:Path Data="{x:Static controls:IconPaths.Info}"
                                     Stroke="{StaticResource ColorTextMuted}"
                                     StrokeThickness="1.5"
                                     StrokeLineCap="Round"
                                     StrokeLineJoin="Round"
                                     Aspect="Uniform"
                                     WidthRequest="18"
                                     HeightRequest="18" />
                    </Grid>
                    <Label Text="About"
                           FontFamily="InterSemiBold"
                           FontSize="16"
                           TextColor="{StaticResource ColorTextMuted}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Label Grid.Column="1"
                       Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                       FontFamily="JetBrainsMono"
                       FontSize="16"
                       TextColor="{StaticResource ColorTextMuted}"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Feature grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="20" RowSpacing="16">

                <!-- Root Authorities -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10">
                    <Grid WidthRequest="20" HeightRequest="20" VerticalOptions="Start" Margin="0,2,0,0">
                        <shapes:Path Data="{x:Static controls:IconPaths.ShieldCheck}"
                                     Stroke="{StaticResource ColorAccentPrimary}"
                                     StrokeThickness="1.5"
                                     StrokeLineCap="Round"
                                     StrokeLineJoin="Round"
                                     Aspect="Uniform"
                                     WidthRequest="20"
                                     HeightRequest="20" />
                    </Grid>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Root Authorities"
                               FontFamily="InterSemiBold"
                               FontSize="15"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label Text="Create and manage local trusted root CAs"
                               FontFamily="InterRegular"
                               FontSize="14"
                               TextColor="{StaticResource ColorTextMuted}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Signed Certificates -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="10">
                    <Grid WidthRequest="20" HeightRequest="20" VerticalOptions="Start" Margin="0,2,0,0">
                        <shapes:Path Data="{x:Static controls:IconPaths.FileBadge}"
                                     Stroke="{StaticResource ColorAccentPrimary}"
                                     StrokeThickness="1.5"
                                     StrokeLineCap="Round"
                                     StrokeLineJoin="Round"
                                     Aspect="Uniform"
                                     WidthRequest="20"
                                     HeightRequest="20" />
                    </Grid>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Signed Certificates"
                               FontFamily="InterSemiBold"
                               FontSize="15"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label Text="Generate child SSL/TLS certificates"
                               FontFamily="InterRegular"
                               FontSize="14"
                               TextColor="{StaticResource ColorTextMuted}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Export Formats -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="10">
                    <Grid WidthRequest="20" HeightRequest="20" VerticalOptions="Start" Margin="0,2,0,0">
                        <shapes:Path Data="{x:Static controls:IconPaths.ArrowUpFromLine}"
                                     Stroke="{StaticResource ColorAccentPrimary}"
                                     StrokeThickness="1.5"
                                     StrokeLineCap="Round"
                                     StrokeLineJoin="Round"
                                     Aspect="Uniform"
                                     WidthRequest="20"
                                     HeightRequest="20" />
                    </Grid>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Export Formats"
                               FontFamily="InterSemiBold"
                               FontSize="15"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label Text="PEM, KEY, and PFX bundles"
                               FontFamily="InterRegular"
                               FontSize="14"
                               TextColor="{StaticResource ColorTextMuted}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Trust Store -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="10">
                    <Grid WidthRequest="20" HeightRequest="20" VerticalOptions="Start" Margin="0,2,0,0">
                        <shapes:Path Data="{x:Static controls:IconPaths.KeyRound}"
                                     Stroke="{StaticResource ColorAccentPrimary}"
                                     StrokeThickness="1.5"
                                     StrokeLineCap="Round"
                                     StrokeLineJoin="Round"
                                     Aspect="Uniform"
                                     WidthRequest="20"
                                     HeightRequest="20" />
                    </Grid>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Trust Store"
                               FontFamily="InterSemiBold"
                               FontSize="15"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label Text="Install roots into your OS trust store"
                               FontFamily="InterRegular"
                               FontSize="14"
                               TextColor="{StaticResource ColorTextMuted}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

            </Grid>

        </VerticalStackLayout>
    </Border>

</ContentView>
