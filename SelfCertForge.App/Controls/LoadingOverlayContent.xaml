<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="SelfCertForge.App.Controls.LoadingOverlayContent"
               BackgroundColor="Transparent"
               Margin="0"
               Padding="0">
    <Border Background="{StaticResource ColorPanelElevated}"
            Stroke="{StaticResource ColorBorderSubtle}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 20"
            Padding="32"
            HorizontalOptions="Center"
            VerticalOptions="Center">
        <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
            <!-- Brand mark, pulsed natively in code-behind. (We avoid Lottie here:
                 the SVGator Lottie export contained only the vendor watermark, not
                 the raster brand art.) -->
            <Image x:Name="Mark"
                   Source="brand_mark.png"
                   Aspect="AspectFit"
                   WidthRequest="96"
                   HeightRequest="96"
                   HorizontalOptions="Center" />
            <Label x:Name="MessageLabel"
                   FontFamily="InterSemiBold"
                   FontSize="18"
                   TextColor="{StaticResource ColorTextPrimary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
