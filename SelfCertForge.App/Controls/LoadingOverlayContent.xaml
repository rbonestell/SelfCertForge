<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="SelfCertForge.App.Controls.LoadingOverlayContent"
               BackgroundColor="Transparent"
               Margin="0"
               Padding="0">
    <Border Background="{StaticResource ColorPanelElevated}"
            Stroke="{StaticResource ColorBorderSubtle}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 20"
            Padding="32"
            HorizontalOptions="Center"
            VerticalOptions="Center">
        <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
            <!-- The hammer-swing animation is a JS-driven SVG (SVGator), which MAUI
                 can't render natively, so we host it in a WebView. Its HTML uses the
                 card surface color as the page background, so there's no transparency
                 seam and no white flash around the animation. -->
            <Grid WidthRequest="140" HeightRequest="140" HorizontalOptions="Center">
                <WebView x:Name="Anim"
                         BackgroundColor="{StaticResource ColorPanelElevated}" />
            </Grid>
            <Label x:Name="MessageLabel"
                   FontFamily="InterSemiBold"
                   FontSize="18"
                   TextColor="{StaticResource ColorTextPrimary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
